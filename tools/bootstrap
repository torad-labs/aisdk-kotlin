#!/usr/bin/env bash
set -euo pipefail

repo="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo" ]; then
  echo "tools/bootstrap: not inside a git worktree" >&2
  exit 1
fi

cd "$repo"

if [ ! -x ".githooks/pre-commit" ]; then
  echo "tools/bootstrap: expected executable .githooks/pre-commit" >&2
  exit 1
fi

current="$(git config --local --get core.hooksPath || true)"
if [ "$current" = ".githooks" ]; then
  echo "tools/bootstrap: core.hooksPath already set to .githooks"
else
  git config --local core.hooksPath .githooks
  echo "tools/bootstrap: set core.hooksPath=.githooks"
fi

echo "tools/bootstrap: local pre-commit gates are active"
